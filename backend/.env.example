# Quantis Backend Configuration
# Copy this to .env and fill in your values

# Alpha Vantage API for fallback market data
# Get your free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Finnhub API for sentiment analysis
# Get your free key at: https://finnhub.io/
FINNHUB_KEY=

# Shoonya API (optional - for live market data)
# Contact: https://shoonya.com/
SHOONYA_API_KEY=
SHOONYA_USER_ID=
SHOONYA_PASSWORD=
SHOONYA_TOKEN=

# Groq API for AI agents (required for debate layer)
# Get your free key at: https://console.groq.com/
GROQ_API_KEY=

# Database Configuration (PostgreSQL via Docker)
POSTGRES_USER=quantis
POSTGRES_PASSWORD=quantis_pass_2024
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quantis

# JWT Configuration
SECRET_KEY=quantis_super_secret_key_change_in_production